# macOS 메타데이터
._*
.DS_Store

# Python 캐시
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# 대용량 패키지 (오프라인 설치용 wheel — 버전별 하위 폴더만 제외)
packages_linux/
packages_mac/
packages_win/py*/
packages_win/spark/

# 원천 데이터 및 모델 (용량/보안)
data/
drugbank/

# 훈련된 모델 파일
models/
mlruns/

# 환경변수
.env
*.env

# Claude Code 로컬 설정
.claude/

# IDE
.idea/
.vscode/

# Codex / OMC 세션 파일
.omc/
.tri-bridge/

# 가상환경
venv/
.venv/
.venv_hana/
.venv_macos/

# 데스크탑 앱 로그 (macOS 개발 환경 fallback 경로 — 윈도우는 %LOCALAPPDATA%)
hana_desktop/

# 로컬 설정 파일
hana_app/hana_config.json

# 미완성 앱 / 비코드 파일 (리뷰 도구 파일명 인코딩 호환성)
hana/*
hira/
error/
lay_out/
python/
*.txt
*.bat
desktop_app.py
web-user-guide.md
.worktrees/

# 설치 스크립트 및 요구사항 파일 추적 허용
!install_all.bat
!install_312.bat
!generate_smoke_dl_bundle.bat
!verify_smoke_dl.bat
!run_api_smoke_dl.bat
!inspect_parquet_history.bat
!download_all.bat
!hana_app/run.bat
!packages_win/install.bat
!packages_win/download.bat
!hana/install.bat
!hana/download.bat
!hana_app/requirements.txt
!packages_win/requirements.txt
!constraints-py312.txt

# 데스크탑 앱 (pywebview) 관련 파일 추적 허용 — 폐쇄망 배포 대상
!desktop_app.py
!run_desktop.bat
!install_pywebview.bat
!download_pywebview.bat
!web-user-guide.md
