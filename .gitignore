# macOS 메타데이터
._*
.DS_Store

# Python 캐시
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# 대용량 패키지 (오프라인 설치용 wheel — 버전별 하위 폴더만 제외)
packages_linux/
packages_mac/
packages_win/py*/
packages_win/spark/

# 원천 데이터 및 모델 (용량/보안)
data/
drugbank/

# 훈련된 모델 파일
models/
mlruns/

# 환경변수
.env
*.env

# Claude Code 로컬 설정
.claude/

# IDE
.idea/
.vscode/

# Codex / OMC 세션 파일
.omc/
.tri-bridge/
